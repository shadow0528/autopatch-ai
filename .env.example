# AutoPatch AI Platform Environment Config
# Rename this file to .env and place it in the root directory before running startup scripts.

# Backend Configuration
AUTOPATCH_SERVER_HOST=0.0.0.0
AUTOPATCH_SERVER_PORT=8000
DATABASE_URL=sqlite:///./autopatch.db
SECRET_KEY=your-super-secret-backend-key-here

# Agent Configuration
AUTOPATCH_SERVER_URL=http://127.0.0.1:8000
AGENT_HEARTBEAT_INTERVAL=30
AGENT_DISCOVERY_INTERVAL=300
AGENT_EXECUTOR_INTERVAL=15
AGENT_MONITORING_INTERVAL=60

# Frontend Configuration
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
